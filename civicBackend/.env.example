# ============================================================
# NagrikSevaSetu - civicBackend Environment Variables
# ============================================================
# STEP 1: Copy this file to a new file named ".env"
# STEP 2: Replace every placeholder value below with real credentials
# NEVER commit the .env file to GitHub (it's in .gitignore)
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB Atlas ---
# Get this from: Atlas Dashboard > Connect > Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/civic_db?retryWrites=true&w=majority

# --- Firebase Admin SDK ---
# Get this from: Firebase Console > Project Settings > Service Accounts > Generate new private key
# The downloaded JSON file contains these values
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_CLIENT_EMAIL=FIREBASE_CLIENT_EMAIL
# IMPORTANT: Replace \n with actual newlines when copying from the JSON file
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# --- Cloudinary ---
# Get this from: Cloudinary Dashboard > Settings > API Keys
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET
CLOUDINARY_UPLOAD_PRESET=YOUR_PRESENT_NAME

# --- CORS ---
# Comma-separated list of allowed origins (no trailing slashes)
# For development: http://localhost:5173 is the Vite dev server
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Gemini AI (for urgency detection) ---
# Get this from: Google AI Studio > Get API Key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
