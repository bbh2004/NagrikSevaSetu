{
  "name": "civic-backend",
  "version": "1.0.0",
  "description": "Common REST API backend for NagrikSevaSetu (civicApp + civicWeb)",
  "main": "src/server.js",
  "scripts": {
    "start": "nodemon src/server.js",
    "start:prod": "node src/server.js",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --forceExit --ci --runInBand",
    "stress-test": "node scripts/testGroqUrgency.js",
    "wipe": "node wipeDB.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "coverageReporters": ["text", "lcov", "clover"],
    "testTimeout": 30000,
    "verbose": true,
    "resetMocks": false,
    "restoreMocks": false
  },
  "dependencies": {
    "cloudinary": "^2.3.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^12.3.0",
    "groq-sdk": "^1.2.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}
